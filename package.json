{
  "name": "momoro-rules-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/boboan.prisma",
    "db:push": "node scripts/with-admin-db.mjs prisma db push --schema=prisma/schema.prisma",
    "db:init-user": "node scripts/init-app-user.mjs",
    "db:setup": "pnpm db:push && pnpm db:init-user",
    "db:check": "node scripts/db-check.mjs",
    "db:pull:boboan": "prisma db pull --schema=prisma/boboan.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "sandbox:test-pyodide": "node scripts/test-pyodide.mjs",
    "sandbox:test-ingamenews": "node scripts/test-fetch-ingamenews.mjs",
    "sandbox:dump-coverage": "node scripts/dump-coverage-analysis.mjs",
    "postinstall": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/boboan.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.0.10",
    "lucide-react": "^0.487.0",
    "mysql2": "^3.14.0",
    "next": "^15.2.4",
    "openai": "^4.91.0",
    "pyodide": "^0.29.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.2.4",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
