generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/boboan-client"
}

datasource db {
  provider = "mysql"
  url      = env("BOBOAN_NET_DB_URL")
}

model User {
  id               String             @id @db.VarChar(36)
  password         String             @db.VarChar(64)
  salt             String             @db.VarChar(8)
  email            String?            @db.VarChar(100)
  status           UserStatus         @default(active)
  create_at        DateTime           @default(now()) @db.DateTime(6)
  update_at        DateTime           @default(now()) @updatedAt @db.DateTime(6)
  nickname         String?            @db.VarChar(100)
  email_verified   Int                @default(0) @db.TinyInt
  mobile           String?            @db.VarChar(20)
  mobile_verified  Int                @default(0) @db.TinyInt
  picture          String?            @db.VarChar(1000)
  username         String             @db.VarChar(100)
  bc_message       bc_message[]
  bc_server        bc_server[]
  bc_server_member bc_server_member[]
  user_roles_role  user_roles_role[]

  @@map("user")
}

model MomoIngameNews {
  key       String   @id @db.VarChar(100)
  map       String?  @db.VarChar(100)
  object    String   @db.VarChar(100)
  objectId  String?  @map("objectId") @db.VarChar(100)
  origin    String   @db.Text
  subject   String   @db.VarChar(100)
  ts        BigInt
  type      Int
  create_at DateTime @default(now()) @db.DateTime(6)
  update_at DateTime @default(now()) @updatedAt @db.DateTime(6)

  @@map("momo_ingamenews")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model bc_channel {
  id               String          @id @db.VarChar(36)
  server_id        String          @db.VarChar(36)
  name             String          @db.VarChar(100)
  topic            String?         @db.VarChar(255)
  type             bc_channel_type @default(text)
  parent_id        String?         @db.VarChar(36)
  position         Int             @default(0)
  create_at        DateTime        @default(now()) @db.DateTime(6)
  update_at        DateTime        @default(now()) @db.DateTime(6)
  deleted_at       DateTime?       @db.DateTime(6)
  bc_channel       bc_channel?     @relation("bc_channelTobc_channel", fields: [parent_id], references: [id], map: "FK_bc_channel_parent_id")
  other_bc_channel bc_channel[]    @relation("bc_channelTobc_channel")
  bc_server        bc_server       @relation(fields: [server_id], references: [id], onDelete: Cascade, map: "FK_bc_channel_server_id")
  bc_message       bc_message[]

  @@index([parent_id], map: "IDX_bc_channel_parent_id")
  @@index([server_id, deleted_at, position], map: "IDX_bc_channel_server_deleted_pos")
  @@index([server_id, position], map: "IDX_bc_channel_server_pos")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model bc_message {
  id               String       @id @db.VarChar(36)
  server_id        String       @db.VarChar(36)
  channel_id       String       @db.VarChar(36)
  author_id        String       @db.VarChar(36)
  content          String       @db.MediumText
  reply_to         String?      @db.VarChar(36)
  edited_at        DateTime?    @db.DateTime(6)
  deleted_at       DateTime?    @db.DateTime(6)
  create_at        DateTime     @default(now()) @db.DateTime(6)
  update_at        DateTime     @default(now()) @db.DateTime(6)
  user             User         @relation(fields: [author_id], references: [id], onDelete: Cascade, map: "FK_bc_message_author_id")
  bc_channel       bc_channel   @relation(fields: [channel_id], references: [id], onDelete: Cascade, map: "FK_bc_message_channel_id")
  bc_message       bc_message?  @relation("bc_messageTobc_message", fields: [reply_to], references: [id], map: "FK_bc_message_reply_to")
  other_bc_message bc_message[] @relation("bc_messageTobc_message")
  bc_server        bc_server    @relation(fields: [server_id], references: [id], onDelete: Cascade, map: "FK_bc_message_server_id")

  @@index([author_id], map: "IDX_bc_message_author_id")
  @@index([channel_id, create_at], map: "IDX_bc_message_channel_create_at")
  @@index([channel_id, deleted_at, create_at], map: "IDX_bc_message_channel_deleted_create_at")
  @@index([deleted_at], map: "IDX_bc_message_deleted_at")
  @@index([reply_to], map: "IDX_bc_message_reply_to")
  @@index([server_id, channel_id], map: "IDX_bc_message_server_channel")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
