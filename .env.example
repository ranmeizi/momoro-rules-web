# ═══════════════════════════════════════════════════════════
# 1. 平台库 momoro_rules（规则 / 执行记录）
#    运行时 Prisma 使用 momoro_app（仅 DML，无 DDL）
# ═══════════════════════════════════════════════════════════
DATABASE_URL="mysql://momoro_app:YOUR_PASSWORD@YOUR_MYSQL_HOST:3306/momoro_rules"

# 开发/迁移专用：有 CREATE/ALTER 权限，仅 pnpm db:push 使用
# 密码含 & @ # 等特殊字符时可直接写，脚本会自动 URL 编码
DATABASE_ADMIN_URL="mysql://root:YOUR_PASSWORD@YOUR_MYSQL_HOST:3306/momoro_rules"

# ═══════════════════════════════════════════════════════════
# 2. boboan_net（登录 user 表 + 游戏公告）
#    boboan.prisma 映射已有表，仅 db pull / generate，勿 db push
# ═══════════════════════════════════════════════════════════
BOBOAN_NET_DB_URL="mysql://YOUR_USER:YOUR_PASSWORD@YOUR_MYSQL_HOST:3306/boboan_net"

# 沙盒只读 momo_ingamenews
MOMO_INGAME_DB_URL="mysql://rules_readonly:YOUR_PASSWORD@YOUR_MYSQL_HOST:3306/boboan_net"

# ═══════════════════════════════════════════════════════════
# 认证
# ═══════════════════════════════════════════════════════════
JWT_SECRET="change-me-to-a-random-secret"

# ═══════════════════════════════════════════════════════════
# 大模型（阿里云百炼 · OpenAI 兼容模式）
# 控制台: https://bailian.console.aliyun.com/
# ═══════════════════════════════════════════════════════════
LLM_API_KEY="sk-..."
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen-plus"
# 代码生成推荐: qwen-coder-plus / qwen-max

SANDBOX_ENGINE=pyodide
# legacy = 受限 Python 转 JS；pyodide = WASM 真实 Python（默认）
SANDBOX_TIMEOUT_MS=30000
SANDBOX_MEMORY_MB=256
SANDBOX_MAX_ROWS=10000

# 掉落时间轴：相距 ≤ 粘滞时间的点合并为活跃段（毫秒，默认 2 小时）
NEXT_PUBLIC_DROP_STICKY_MS=7200000

# 可选，生产环境建议设置（构建 Boboan redirect_uri 时使用）
# NEXT_PUBLIC_APP_URL="https://your-momoro-domain.com"
NEXT_PUBLIC_BOBOAN_LOGIN_URL="https://boboan.net/login"

ADMIN_API_KEY="change-me-admin-key"
